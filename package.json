{
  "name": "mega-coder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev:web": "npm run dev -w @mega-coder/web",
    "build:web": "npm run build -w @mega-coder/web",
    "preview:web": "npm run preview -w @mega-coder/web",
    "dev:electron": "npm run build:web && electron .",
    "build:electron": "npm run build:web && electron-builder",
    "build:electron:mac": "npm run build:web && electron-builder --mac --publish never"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1"
  },
  "build": {
    "appId": "com.mega-coder.app",
    "productName": "MEGA CODER",
    "directories": {
      "buildResources": "electron/assets"
    },
    "files": [
      "electron/**/*",
      "apps/web/dist/**/*",
      "apps/web/public/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "icon": null,
      "sign": false,
      "notarize": false
    }
  }
}

